# Amadeus MVP 环境变量示例
# 复制为 .env 并填入你的密钥: cp .env.example .env

# 通用 OpenAI 兼容 API（旧版配置，仍然可用）：
# 若下面的 LLM/Embedding/STT/TTS 未单独配置，会回退到此处。
OPENAI_API_KEY=sk-your-openai-or-compatible-key
# OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1

# ===== 推荐：聊天走 Groq 免费，Embedding/STT/TTS 继续用 OpenAI =====

# LLM（Groq 等 OpenAI 兼容服务）
# LLM_API_KEY=groq_your_api_key_here
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# Embedding（建议保持使用 OpenAI，费用极低）
# EMBEDDING_API_KEY=sk-your-openai-key
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# ===== 纯本地免费 Embedding（推荐给没有 OpenAI 配额的情况）=====
# 开启后，RAG 的向量化完全使用本地模型，不调用 Embedding API
# USE_LOCAL_EMBEDDINGS=true
# LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# TTS（默认用 OpenAI TTS）
# TTS_API_KEY=sk-your-openai-key
# TTS_BASE_URL=https://api.openai.com/v1
# TTS_MODEL=tts-1
# TTS_VOICE=alloy

# STT / Whisper
# STT_API_KEY=sk-your-openai-key
# STT_BASE_URL=https://api.openai.com/v1
# STT_MODEL=whisper-1

# 使用免费 edge-tts 代替 OpenAI TTS（不消耗 OpenAI 额度）
# USE_EDGE_TTS=true
# EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# RAG 向量库持久化目录
# CHROMA_PERSIST_DIR=./data/chroma

# 服务监听
# HOST=0.0.0.0
# PORT=8000
